/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# editor / IDE configs (personal, don't leak across collaborators)
.vscode/
.idea/
*.iml
*.swp
*.swo

# AI assistant configs (project-local, not for sharing)
.claude/
.cursor/
.aider*

# planning / audit / notes (Claude plans and scratch docs)
analyze-this-*.md
/plans/
/notes/
TODO.md
NOTES.md
SCRATCH.md
*.draft.md

# local screenshots / build artifacts
/screenshots/
/artifacts/
*.local.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — Tier 2 env separation: `.env*` blanks everything, then the
# three `.example` templates are opted back in. Never commit `.env`,
# `.env.local`, `.env.staging`, or `.env.production`.
.env*
!.env.example
!.env.local.example
!.env.staging.example

# local SQLite scratch databases (dev only — real DB is Postgres)
*.db
*.db-journal
*.db-wal
*.db-shm

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
