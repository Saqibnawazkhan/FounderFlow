# =============================================================================
# FounderFlow — LOCAL development env (Tier 2 env separation)
#
# Copy to `.env.local` (which is gitignored) and use as-is unless you edited
# POSTGRES_PASSWORD in docker-compose.yml.
#
# What this file replaces:
#   Before Tier 2 the project used a single `.env` whose DATABASE_URL pointed
#   at the production Supabase. That's how the seed script once wiped a real
#   signup's account. Now dev = local docker Postgres, staging = a distinct
#   Supabase project (see .env.staging.example), prod = untouched from an
#   agent workflow.
#
# Setup from scratch:
#   1. `docker compose up -d`             — brings up postgres on 127.0.0.1:5433
#   2. `cp .env.local.example .env.local` — this file
#   3. `npm run db:migrate:local`         — applies every migration
#   4. `npm run db:seed:local`            — loads the demo workspace
#   5. `npm run dev`                      — Next.js reads .env.local first
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="PKR"

# --- Database ---
# Points at the docker-compose Postgres on 127.0.0.1:5433. No pooler wrapper
# needed locally — the whole point is one client, no serverless cold-start.
# If you changed POSTGRES_PASSWORD in docker-compose.yml, mirror it here.
DATABASE_URL="postgresql://founderflow:founderflow_local@127.0.0.1:5433/founderflow?schema=public"
DIRECT_URL="postgresql://founderflow:founderflow_local@127.0.0.1:5433/founderflow?schema=public"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
# The demo secret below is FINE for local dev only. Rotate before any
# environment that faces a real user.
AUTH_SECRET="local-dev-secret-do-not-use-in-prod-9f8a2c1e4b6d0a"
AUTH_URL="http://localhost:3000"

# --- Email ---
# Leave both blank in local dev — lib/email/send.ts logs invite / reset URLs
# to the server console so you can click through without needing SMTP.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM=""

# --- Cron ---
# Local dev doesn't run the Vercel cron, so this can stay blank. If you want
# to hit /api/cron/materialize-recurring locally, set it to any random string
# and pass the same string in the Authorization: Bearer header.
CRON_SECRET=""

# --- Rate limiting ---
# Set to "true" if you're stress-testing auth locally (Puppeteer smoke tests
# fire 20+ logins/sec and the 5/min bucket will block them).
RATE_LIMIT_DISABLED="false"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- LemonSqueezy (subscription billing) ---
# Merchant-of-record billing — works for sellers in countries Stripe won't
# onboard (e.g. Pakistan). Leave BLANK to disable billing entirely; the app
# runs fine and Settings → Plan shows "not configured". To enable in TEST mode:
#   1. LemonSqueezy → Settings → API → create an API key (test-mode store).
#   2. Store → note the STORE ID (the number in the store URL / Settings).
#   3. Products → create a subscription product + monthly variant for "Team";
#      copy the VARIANT id into LEMONSQUEEZY_VARIANT_ID_TEAM.
#   4. Settings → Webhooks → add https://<domain>/api/webhooks/lemonsqueezy
#      subscribed to the subscription_* events, with a signing secret you also
#      paste into LEMONSQUEEZY_WEBHOOK_SECRET. (Locally, expose :3000 with a
#      tunnel like ngrok and point the webhook at it.)
# The checkout redirect URL uses NEXT_PUBLIC_APP_URL (set above).
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_VARIANT_ID_TEAM=""
LEMONSQUEEZY_WEBHOOK_SECRET=""

# --- Observability ---
# All blank locally — Sentry SDK no-ops without a DSN. Filling any of these
# in dev would spam your prod Sentry project with local noise.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Optional: docker-compose overrides ---
# Only set these if you edited docker-compose.yml. Otherwise the compose
# file's defaults apply.
POSTGRES_USER="founderflow"
POSTGRES_PASSWORD="founderflow_local"
POSTGRES_DB="founderflow"
