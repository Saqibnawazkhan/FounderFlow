{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "node scripts/vercel-build.mjs",
  "crons": [
    {
      "path": "/api/cron/materialize-recurring",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/sweep-time-entries",
      "schedule": "10 0 * * *"
    },
    {
      "path": "/api/cron/purge-soft-deleted",
      "schedule": "15 3 * * *"
    }
  ]
}
