# =============================================================================
# FounderFlow — Environment Configuration
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="PKR"

# --- Database (Phase 1) ---
# Postgres connection string. Format: postgres://user:pass@host:5432/db?schema=public
DATABASE_URL=""

# --- Auth.js (Phase 1) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Email (Phase 1, optional in dev) ---
# Set EMAIL_VERIFICATION_REQUIRED=false to skip in development
EMAIL_VERIFICATION_REQUIRED="false"
RESEND_API_KEY=""
EMAIL_FROM="FounderFlow <noreply@founderflow.app>"

# --- Rate limiting (Phase 5, optional) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Observability (Phase 5, optional) ---
SENTRY_DSN=""
