# =============================================================================
# FounderFlow — Environment Configuration
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="PKR"

# --- Database (Phase 1) ---
# Supabase Postgres. Two URLs because the Prisma client uses the pooled
# connection at runtime, but `prisma migrate` needs a direct connection.
#
# Get both from: Supabase dashboard -> Project Settings -> Database ->
#   "Connection string" panel
#
#   DATABASE_URL  -> "Transaction pooler" (port 6543, ends in pooler.supabase.com)
#   DIRECT_URL    -> "Direct connection"  (port 5432, ends in db.<ref>.supabase.co)
#
# Append `?pgbouncer=true&connection_limit=1` to DATABASE_URL for serverless.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"

# --- Auth.js (Phase 1) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Email (Phase 6: invite-by-email flow) ---
# Resend free tier (3K emails/month) covers all transactional email needs.
# In dev, leave RESEND_API_KEY empty — the email helper falls back to
# logging the full HTML + invite URL to the server console so you can copy
# the link manually for testing.
#
# To activate in prod:
#   1. Sign up at https://resend.com → get an API key (re_xxx)
#   2. Verify your sending domain in Resend → required to use a custom
#      EMAIL_FROM; otherwise leave it empty and Resend's onboarding@resend.dev
#      sandbox sender is used (great for personal projects, capped at low volume)
RESEND_API_KEY=""
EMAIL_FROM="FounderFlow <onboarding@resend.dev>"

# --- Rate limiting (Phase 5) ---
# In-memory rate limiter in lib/rate-limit.ts protects auth (5/min/IP) and
# write actions (60/min/userId) out of the box. Set RATE_LIMIT_DISABLED=true
# in local dev or CI smoke tests to bypass — production should never set this.
RATE_LIMIT_DISABLED="false"
# Optional: swap in Upstash Redis for multi-instance / multi-region prod.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Observability (Phase 5, optional) ---
# Leave all of these empty in dev — the SDK no-ops cleanly without a DSN.
# Server-side errors report via SENTRY_DSN; browser errors use the public one.
# In production:
#   1. Create a Sentry project at https://sentry.io (Next.js platform)
#   2. Paste the DSN into BOTH SENTRY_DSN and NEXT_PUBLIC_SENTRY_DSN
#   3. (Optional, for source-map upload) generate an internal-integration auth
#      token in Settings -> Auth Tokens and paste below. Without it, error
#      stacks ship minified.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
