# =============================================================================
# FounderFlow — STAGING env (Tier 2 env separation)
#
# Copy to `.env.staging` (gitignored) and fill in with a SECOND Supabase
# project's credentials — never the production one. CI targets this env.
#
# How to create the staging Supabase project:
#   1. Sign in to https://supabase.com/dashboard
#   2. "New project" → same region as prod, free tier is fine
#   3. Project name suggestion: `founderflow-staging`
#   4. Project Settings → Database → Connection string:
#        DATABASE_URL  = "Transaction pooler" (port 6543)
#        DIRECT_URL    = "Direct connection"  (port 5432)
#   5. Rotate AUTH_SECRET (`openssl rand -base64 32`) — staging must NOT
#      reuse the production secret; a shared secret means a stolen staging
#      JWT would sail into prod.
#   6. Add these values to Vercel's staging environment (Project → Settings
#      → Environment Variables, scope = "Preview")
#
# CI should run migrations against staging on every merge to main:
#   `npx prisma migrate deploy` (NOT `migrate dev` — deploy is prod-safe,
#   never generates new migrations, only applies existing ones).
# =============================================================================

NEXT_PUBLIC_APP_URL="https://founderflow-staging.vercel.app"
NEXT_PUBLIC_DEFAULT_CURRENCY="PKR"

# Fill from the "founderflow-staging" Supabase project — NOT prod.
DATABASE_URL="postgresql://postgres.<staging-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<staging-ref>.supabase.co:5432/postgres"

# openssl rand -base64 32 — must differ from prod
AUTH_SECRET=""
AUTH_URL="https://founderflow-staging.vercel.app"

# Same Gmail infra as prod is OK — recipients see the same "FounderFlow"
# sender. Or provision a distinct app-password so staging bounces don't
# eat prod's Gmail quota.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM=""

CRON_SECRET=""
RATE_LIMIT_DISABLED="false"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Distinct Sentry project so staging noise doesn't pollute prod's issue list.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
