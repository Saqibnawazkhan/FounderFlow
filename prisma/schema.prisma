// FounderFlow schema. SQLite for local dev; swap `provider = "postgresql"`
// and update DATABASE_URL to ship to Supabase/Neon. The model shape mirrors
// the TypeScript interfaces in lib/types.ts so the same code can call either
// path during the Zustand -> server-action migration.
//
// Notes on SQLite vs Postgres:
// - SQLite has no enums; role/type/status fields are stored as strings with
//   the allowed values documented inline. Zod schemas in lib/schemas/ are
//   the source of truth at the application boundary.
// - createdAt uses DateTime (stored as ISO 8601 string in SQLite).

generator client {
  provider = "prisma-client-js"
  // Generate engines for both the local dev OS (native) AND Vercel's
  // serverless runtime (Linux + OpenSSL 3). Without the rhel target, the
  // deployed function throws PrismaClientInitializationError "could not
  // locate the Query Engine for runtime rhel-openssl-3.0.x".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  // No `output` override — keep the default node_modules/.prisma/client
  // location so Next.js's serverless file tracing auto-includes the .so.node
  // engine binary in the deployment bundle.
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl is used by `prisma migrate` and introspection; it must bypass
  // any connection pooler. On Supabase: DATABASE_URL is the transaction
  // pooler (port 6543), DIRECT_URL is the direct connection (port 5432).
  // For local dev a single direct URL in both vars works fine.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String // bcrypt hash, never the raw password
  role         String // "admin" | "cofounder" | "member"
  avatar       String?
  companyId    String
  createdAt    DateTime @default(now())

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownedCompany   Company?        @relation("CompanyOwner")
  transactions   Transaction[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")
  activities     Activity[]
  notifications  Notification[]
  recurringRules RecurringRule[]

  @@index([companyId])
  @@index([email])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String
  currency  String   @default("PKR")
  // Nullable to break the circular FK with User (User.companyId required,
  // and Company would also require ownerId). The signup server action
  // creates the company first, then the owner, then updates ownerId.
  ownerId   String?  @unique
  createdAt DateTime @default(now())

  owner          User?           @relation("CompanyOwner", fields: [ownerId], references: [id])
  users          User[]
  transactions   Transaction[]
  tasks          Task[]
  activities     Activity[]
  notifications  Notification[]
  inviteTokens   InviteToken[]
  recurringRules RecurringRule[]
}

model Transaction {
  id          String   @id @default(cuid())
  companyId   String
  type        String // "expense" | "investment"
  amount      Float
  category    String
  description String
  date        DateTime
  addedBy     String
  addedByName String // denormalized for fast read paths
  createdAt   DateTime @default(now())

  // Set when this row was materialized from a RecurringRule. Lets the UI
  // show a 🔁 badge and lets the user audit which rule generated what.
  // Null for manually-created transactions. SetNull on rule delete so the
  // history survives if the user removes the rule.
  ruleId String?
  rule   RecurringRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [addedBy], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([companyId, type])
  @@index([addedBy])
  @@index([ruleId])
}

// Repeating-transaction template. A daily cron at /api/cron/materialize-recurring
// scans active rules and creates a Transaction whenever today matches the
// rule's frequency window AND we haven't already materialized today.
//
// frequency = "monthly" → uses dayOfMonth (1-31; clamped to month length
//                          so dayOfMonth=31 fires on Feb 28/29)
// frequency = "weekly"  → uses dayOfWeek (0=Sun … 6=Sat)
//
// We keep both day fields nullable to avoid a column-per-frequency table —
// the materializer + zod schema enforce that the right one is set.
model RecurringRule {
  id            String  @id @default(cuid())
  companyId     String
  type          String // "expense" | "investment"
  amount        Float
  category      String
  description   String
  addedBy       String // userId who created the rule
  addedByName   String // denormalized (same pattern as Transaction)
  frequency     String // "monthly" | "weekly"
  dayOfMonth    Int? // 1-31 (when frequency=monthly)
  dayOfWeek     Int? // 0-6  (when frequency=weekly)
  active        Boolean @default(true)
  // First-fire date — also the date used for the immediate "seed" transaction
  // we create at rule-creation time so the user gets instant feedback.
  startDate     DateTime
  // Set on every successful materialization so the cron can detect "already
  // ran today" and stay idempotent if it fires twice in a 24h window.
  lastMaterializedAt DateTime?
  createdAt     DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [addedBy], references: [id], onDelete: Cascade)
  transactions Transaction[] // materialized children — survives rule deletion

  @@index([companyId, active])
  @@index([active, frequency])
}

model Task {
  id             String    @id @default(cuid())
  companyId      String
  title          String
  description    String
  status         String // "pending" | "in_progress" | "completed"
  priority       String // "low" | "medium" | "high" | "urgent"
  assignedTo     String
  assignedToName String
  assignedBy     String
  assignedByName String
  deadline       DateTime
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee User    @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: Cascade)
  creator  User    @relation("TaskCreator", fields: [assignedBy], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([assignedTo])
}

model Activity {
  id        String   @id @default(cuid())
  companyId String
  type      String // ActivityType union from lib/types.ts
  message   String
  userId    String
  userName  String
  metadata  String? // JSON-encoded ActivityMetadata discriminated union
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  title     String
  message   String
  type      String // "info" | "success" | "warning" | "danger"
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Closes audit flaw #7: admins no longer set temp passwords directly. The
// invite action stores a row here + emails a one-time link; the recipient
// sets their own password on accept. Rows are single-use (usedAt set on
// accept) and expire after 7 days (expiresAt checked at accept-time).
//
// We deliberately do NOT create the User row at invite-time — that would
// leave a placeholder account with no password if the invite is never
// accepted, and it'd block the same email from re-inviting later.
model InviteToken {
  id         String    @id @default(cuid())
  token      String    @unique // random ~32-char, used in the email URL
  email      String // lowercased, what the invitee will sign in with
  name       String
  role       String // "cofounder" | "member"  (never "admin" — separate flow)
  companyId  String
  invitedBy  String // userId of the admin who sent the invite
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([companyId])
}
