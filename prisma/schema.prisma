// FounderFlow schema. SQLite for local dev; swap `provider = "postgresql"`
// and update DATABASE_URL to ship to Supabase/Neon. The model shape mirrors
// the TypeScript interfaces in lib/types.ts so the same code can call either
// path during the Zustand -> server-action migration.
//
// Notes on SQLite vs Postgres:
// - SQLite has no enums; role/type/status fields are stored as strings with
//   the allowed values documented inline. Zod schemas in lib/schemas/ are
//   the source of truth at the application boundary.
// - createdAt uses DateTime (stored as ISO 8601 string in SQLite).

generator client {
  provider      = "prisma-client-js"
  // Generate engines for both the local dev OS (native) AND Vercel's
  // serverless runtime (Linux + OpenSSL 3). Without the rhel target, the
  // deployed function throws PrismaClientInitializationError "could not
  // locate the Query Engine for runtime rhel-openssl-3.0.x".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  // No `output` override — keep the default node_modules/.prisma/client
  // location so Next.js's serverless file tracing auto-includes the .so.node
  // engine binary in the deployment bundle.
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl is used by `prisma migrate` and introspection; it must bypass
  // any connection pooler. On Supabase: DATABASE_URL is the transaction
  // pooler (port 6543), DIRECT_URL is the direct connection (port 5432).
  // For local dev a single direct URL in both vars works fine.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String // bcrypt hash, never the raw password
  role         String // "admin" | "cofounder" | "member"
  avatar       String?
  companyId    String
  createdAt    DateTime  @default(now())
  // Updated by the Auth.js signIn callback. Surfaces on /settings as
  // "Last sign-in" so the user can spot rogue logins. Nullable for
  // legacy rows that predate the column.
  lastSignInAt DateTime?
  // Tier 3 soft-delete sentinel. NULL = live row. Any timestamp = soft
  // deleted; the row survives until the nightly purge cron hard-deletes
  // it after 90 days. Auth + queries filter `deletedAt: null` so a
  // soft-deleted user can't sign in and their data isn't rendered, but
  // ops can restore with `UPDATE "User" SET "deletedAt" = NULL`.
  deletedAt    DateTime?

  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownedCompany       Company?        @relation("CompanyOwner")
  transactions       Transaction[]
  assignedTasks      Task[]          @relation("TaskAssignee")
  createdTasks       Task[]          @relation("TaskCreator")
  activities         Activity[]
  notifications      Notification[]
  recurringRules     RecurringRule[]
  budgets            Budget[]
  comments           Comment[]       @relation("CommentAuthor")
  timeEntries        TimeEntry[]     @relation("TimeEntryUser")
  editedEntries      TimeEntry[]     @relation("TimeEntryEditor")
  // Projects this user supervises (1:N — one user can supervise many).
  // SetNull on delete so the project survives the supervisor leaving;
  // the actions layer re-assigns via changeSupervisorAction immediately
  // after, but the DB never blocks the user delete.
  supervisedProjects Project[]       @relation("ProjectSupervisor")
  createdProjects    Project[]       @relation("ProjectCreator")

  @@index([companyId])
  @@index([email])
  @@index([deletedAt])
}

model Company {
  id        String    @id @default(cuid())
  name      String
  industry  String
  currency  String    @default("PKR")
  // Nullable to break the circular FK with User (User.companyId required,
  // and Company would also require ownerId). The signup server action
  // creates the company first, then the owner, then updates ownerId.
  ownerId   String?   @unique
  createdAt DateTime  @default(now())
  // Tier 3 soft-delete sentinel — see User.deletedAt for semantics.
  deletedAt DateTime?

  owner          User?           @relation("CompanyOwner", fields: [ownerId], references: [id])
  users          User[]
  transactions   Transaction[]
  tasks          Task[]
  activities     Activity[]
  notifications  Notification[]
  inviteTokens   InviteToken[]
  recurringRules RecurringRule[]
  budgets        Budget[]
  comments       Comment[]
  timeEntries    TimeEntry[]
  projects       Project[]

  @@index([deletedAt])
}

model Transaction {
  id          String    @id @default(cuid())
  companyId   String
  type        String // "expense" | "investment"
  // Decimal(12, 2) — up to 10 billion with cent precision. Previously
  // `Float`, which drifts on SUM() past a few million rows and can't
  // represent 0.10 exactly. See BUGS.md P0-4.
  amount      Decimal   @db.Decimal(12, 2)
  category    String
  description String
  date        DateTime
  addedBy     String
  addedByName String // denormalized for fast read paths
  createdAt   DateTime  @default(now())
  // Tier 3 soft-delete sentinel — see User.deletedAt for semantics.
  deletedAt   DateTime?

  // Set when this row was materialized from a RecurringRule. Lets the UI
  // show a 🔁 badge and lets the user audit which rule generated what.
  // Null for manually-created transactions. SetNull on rule delete so the
  // history survives if the user removes the rule.
  ruleId String?
  rule   RecurringRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  // Optional project tag. When set, this transaction counts against the
  // project's category budget(s); when null, it counts against company-wide
  // budgets only. Existing rows are null after migration — pre-projects
  // transactions remain company-global.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [addedBy], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([companyId, date])
  @@index([companyId, type])
  @@index([addedBy])
  @@index([ruleId])
  @@index([projectId, date])
  @@index([deletedAt])
}

// Repeating-transaction template. A daily cron at /api/cron/materialize-recurring
// scans active rules and creates a Transaction whenever today matches the
// rule's frequency window AND we haven't already materialized today.
//
// frequency = "monthly" → uses dayOfMonth (1-31; clamped to month length
//                          so dayOfMonth=31 fires on Feb 28/29)
// frequency = "weekly"  → uses dayOfWeek (0=Sun … 6=Sat)
//
// We keep both day fields nullable to avoid a column-per-frequency table —
// the materializer + zod schema enforce that the right one is set.
model RecurringRule {
  id                 String    @id @default(cuid())
  companyId          String
  type               String // "expense" | "investment"
  // See Transaction.amount comment — same precision, same reason.
  amount             Decimal   @db.Decimal(12, 2)
  category           String
  description        String
  addedBy            String // userId who created the rule
  addedByName        String // denormalized (same pattern as Transaction)
  frequency          String // "monthly" | "weekly"
  dayOfMonth         Int? // 1-31 (when frequency=monthly)
  dayOfWeek          Int? // 0-6  (when frequency=weekly)
  active             Boolean   @default(true)
  // First-fire date — also the date used for the immediate "seed" transaction
  // we create at rule-creation time so the user gets instant feedback.
  startDate          DateTime
  // Set on every successful materialization so the cron can detect "already
  // ran today" and stay idempotent if it fires twice in a 24h window.
  lastMaterializedAt DateTime?
  createdAt          DateTime  @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [addedBy], references: [id], onDelete: Cascade)
  transactions Transaction[] // materialized children — survives rule deletion

  @@index([companyId, active])
  @@index([active, frequency])
}

model Task {
  id             String    @id @default(cuid())
  companyId      String
  // Required after the add_projects migration backfills every legacy row
  // to a "General" project per company. onDelete: Restrict so a project
  // can't be deleted while it still has tasks — admins must archive or
  // reparent tasks first.
  projectId      String
  title          String
  description    String
  status         String // "pending" | "in_progress" | "completed"
  priority       String // "low" | "medium" | "high" | "urgent"
  assignedTo     String
  assignedToName String
  assignedBy     String
  assignedByName String
  deadline       DateTime
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  // Tier 3 soft-delete sentinel — see User.deletedAt for semantics.
  deletedAt      DateTime?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  assignee    User        @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: Cascade)
  creator     User        @relation("TaskCreator", fields: [assignedBy], references: [id], onDelete: Cascade)
  comments    Comment[]
  timeEntries TimeEntry[]

  @@index([companyId, status])
  @@index([projectId, status])
  @@index([assignedTo])
  @@index([deletedAt])
}

model Activity {
  id        String   @id @default(cuid())
  companyId String
  // Optional project tag. Project-scoped events (project_created,
  // task_created, supervisor changed, etc.) carry the projectId so the
  // per-project Activity tab can filter without scanning every event.
  // SetNull on project delete so historical events outlive the project.
  projectId String?
  type      String // ActivityType union from lib/types.ts
  message   String
  userId    String
  userName  String
  metadata  String? // JSON-encoded ActivityMetadata discriminated union
  createdAt DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([projectId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  // Optional project scope — set for project-scoped notifications
  // (supervisor assigned, project task created, project budget alerted).
  // Drives the read-side strip-finance-for-members filter so we can keep
  // serving members project pings without leaking non-project budget alerts.
  projectId String?
  title     String
  message   String
  type      String // "info" | "success" | "warning" | "danger"
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  // Company-scoped reads (workspace export, admin views) were doing a full
  // table scan — Notification was the one company-scoped table with no
  // companyId-leading index. Matches the pattern on Transaction/Comment/etc.
  @@index([companyId, createdAt])
}

// Closes audit flaw #7: admins no longer set temp passwords directly. The
// invite action stores a row here + emails a one-time link; the recipient
// sets their own password on accept. Rows are single-use (usedAt set on
// accept) and expire after 7 days (expiresAt checked at accept-time).
//
// We deliberately do NOT create the User row at invite-time — that would
// leave a placeholder account with no password if the invite is never
// accepted, and it'd block the same email from re-inviting later.
model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique // random ~32-char, used in the email URL
  email     String // lowercased, what the invitee will sign in with
  name      String
  role      String // "cofounder" | "member"  (never "admin" — separate flow)
  companyId String
  invitedBy String // userId of the admin who sent the invite
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([companyId])
}

// Per-category monthly spending caps. Threshold check happens inside
// addTransactionAction: after the txn commits, sum month-to-date expenses
// for that category and fan out a notification to all company members if
// we crossed 80% (warning) or 100% (alert). Both thresholds fire once per
// month per budget — `lastWarnedMonth` and `lastAlertedMonth` track which
// "YYYY-MM" string the budget last fired for so we don't spam.
model Budget {
  id               String    @id @default(cuid())
  companyId        String
  // Required after add_projects backfills every legacy row to a "General"
  // project per company. onDelete: Restrict so a project can't be deleted
  // while it still has budgets attached (admin must archive or reparent).
  projectId        String
  category         String // single expense category, e.g. "Office Rent"
  // Decimal(12, 2) matches Transaction.amount so any (limit − sum) math
  // stays on the same numeric domain. See BUGS.md P0-4.
  monthlyLimit     Decimal   @db.Decimal(12, 2)
  createdBy        String
  createdByName    String
  active           Boolean   @default(true)
  // "2026-05" sentinels — set when the corresponding threshold fired this
  // calendar month; cleared/rotated on first hit of the next month.
  lastWarnedMonth  String? // 80%+ fired in this YYYY-MM
  lastAlertedMonth String? // 100%+ fired in this YYYY-MM
  createdAt        DateTime  @default(now())
  // Tier 3 soft-delete sentinel — see User.deletedAt for semantics.
  deletedAt        DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  // One active budget per category per project (paused budgets are excluded
  // via partial-unique-emulation in the action layer; SQL unique can't be
  // conditional on `active` in Postgres without an expression index).
  @@index([companyId, active])
  @@index([companyId, category])
  @@index([projectId, active])
  @@index([projectId, category])
  @@index([deletedAt])
}

// Threaded discussion attached to either a Task or a Transaction (XOR —
// exactly one of taskId / transactionId is non-null; enforced in the zod
// schema and the createCommentAction). One model instead of two parallel
// tables means a unified <CommentThread> component, one server action, and
// one query path.
//
// @mentions: the action parses the raw body for @first-last tokens, looks
// up matching company users, stores their IDs in `mentions` (JSON array)
// for fast read-side highlighting, and fans out a Notification to each.
// The author is never mentioned (no self-pings).
model Comment {
  id            String    @id @default(cuid())
  companyId     String
  body          String // raw text; UI parses @mentions client-side for display
  authorId      String
  authorName    String // denormalized — survives author rename
  authorAvatar  String? // denormalized
  taskId        String?
  transactionId String?
  // JSON array of resolved userIds — `["cuid1","cuid2"]`. Stored so the
  // read path doesn't need to re-parse + DB-lookup every render. Empty
  // array (not null) when no mentions; keeps the read shape predictable.
  mentions      String    @default("[]")
  createdAt     DateTime  @default(now())
  editedAt      DateTime?

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author      User         @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([transactionId, createdAt])
  @@index([companyId, createdAt])
  @@index([authorId])
}

// Per-user work session. `clockOutAt = null` means "currently clocked in".
//
// Auto-close pipeline:
//   • Client heartbeats lastActivityAt every 5 minutes while clocked in.
//   • At 12h since lastActivityAt, the client shows a "still working?" modal.
//   • If the user doesn't respond within 30 min, the client auto-clocks-out
//     with clockOutAt = lastActivityAt (so AFK time isn't credited).
//   • An hourly server cron sweeps any entry where lastActivityAt < now - 12.5h
//     and closes it the same way — safety net for a closed browser tab.
//
// Permissions in lib/actions/time.ts:
//   • Members can clock in/out and delete their own entries — they CANNOT
//     adjust clockInAt/clockOutAt manually.
//   • Admin and cofounder can edit any entry's times (audit-trailed via
//     editedBy + editedAt) and see the whole company's entries.
model TimeEntry {
  id             String    @id @default(cuid())
  companyId      String
  // Optional project tag — entries can stay "general work" (null). If both
  // taskId and projectId are set, the picker UI keeps them in sync (the
  // task's project wins). SetNull on delete so historical hours survive.
  projectId      String?
  projectName    String? // denormalized snapshot of the project name at clock-in
  userId         String
  userName       String // denormalized — survives user rename
  taskId         String? // optional — entry can be "untagged" general work
  taskTitle      String? // denormalized snapshot of the task name at clock-in
  note           String?
  clockInAt      DateTime  @default(now())
  clockOutAt     DateTime? // null = currently active
  // Heartbeat target — every successful client heartbeat sets this to now().
  // Drives both the in-app warning trigger AND the cron auto-close cutoff.
  lastActivityAt DateTime  @default(now())
  // Set to true when either the client idle handler OR the server cron
  // closed the entry instead of the user clicking clock-out. Lets the UI
  // show an "auto-closed" hint and helps debugging.
  autoClosed     Boolean   @default(false)
  // Manual edit audit trail. Set whenever admin/cofounder adjusts the times.
  editedBy       String?
  editedByName   String?
  editedAt       DateTime?
  createdAt      DateTime  @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User     @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)
  editor  User?    @relation("TimeEntryEditor", fields: [editedBy], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, clockInAt])
  @@index([companyId, clockInAt])
  @@index([taskId])
  @@index([projectId, clockInAt])
  // Lets the cron find open entries to auto-close without scanning every row.
  @@index([clockOutAt, lastActivityAt])
}

// A project is the unit founders plan against — owns tasks, budgets, time
// entries, and optionally transactions. One company can own any number of
// projects.
//
// Supervisor model:
//   - Each project has exactly one supervisorId (User).
//   - The supervisor gets ELEVATED permissions inside this project:
//     manage its tasks and budgets, see its finance figures, even when
//     their global role is "member". See lib/auth/project-permissions.ts.
//   - Supervisor can be reassigned (admin/cofounder only) via
//     changeSupervisorAction; an Activity row + a Notification land on
//     the new supervisor.
//
// Visibility for members:
//   - A member sees a project iff they're the supervisor OR they have at
//     least one assigned task in it. Derived in listProjectsForUser().
//   - There's no separate ProjectMember table — task assignments + the
//     supervisor FK encode "who's on this project."
//
// Migration & backfill:
//   - The add_projects migration creates one "General" project per company
//     and back-fills every existing Task + Budget row's projectId there.
//   - After that backfill, Task.projectId and Budget.projectId are NOT NULL.
model Project {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  description   String? // one-line summary shown on cards
  supervisorId  String
  // Lifecycle: active | on_hold | completed | archived. Status drives the
  // default filter on /projects (archived hidden by default) and shifts
  // the card's visual tone.
  status        String    @default("active")
  // Color tag drawn from a fixed palette (primary | cyan | pink | warning
  // | info). Stored as a string slug, NOT a hex — keeps swatches in lock
  // step with the design tokens defined in app/globals.css.
  color         String    @default("primary")
  // Optional planned end. When set + status="active" + past today, the
  // project card renders an overdue chip.
  targetEndDate DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  // Tier 3 soft-delete sentinel — see User.deletedAt for semantics.
  deletedAt     DateTime?

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supervisor User    @relation("ProjectSupervisor", fields: [supervisorId], references: [id])
  creator    User    @relation("ProjectCreator", fields: [createdBy], references: [id])

  tasks         Task[]
  budgets       Budget[]
  timeEntries   TimeEntry[]
  transactions  Transaction[]
  activities    Activity[]
  notifications Notification[]

  @@index([companyId, status])
  @@index([supervisorId])
  @@index([deletedAt])
}
